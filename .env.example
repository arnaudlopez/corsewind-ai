METEOFRANCE_API_KEY=

# Optional: direct MeteoHub/CNR-ISAC MOLOCH GRIB/NetCDF bundle URL or local file.
# The builder also accepts a pre-normalized CorseWind JSON layer.
MOLOCH_SOURCE_URL=

# Optional: override the auto-discovered MeteoHub ICON-2I GRIB bundle URL/local file.
# Leave empty to let the ICON-2I builder select the latest public bundle.
ICON2I_SOURCE_URL=

# Optional: WindNinja is disabled by default in the Portainer-safe compose.
# Model layers still refresh. A future WindNinja-enabled deployment needs the
# host Docker socket and a host-visible repository path.
WINDNINJA_ENABLED=false

# Optional: ML dataset archive and satellite collectors.
# For any backfill larger than a small smoke test, point this to an external
# disk with hundreds of GB free, then run:
# python3 scripts/ml_dataset/storage_preflight.py --ml-root "$ML_DATASET_ROOT" --min-free-gb 250 --create
ML_DATASET_ROOT=data/processed/ml_dataset
ML_DATASET_MIN_FREE_GB=250
ML_DATASET_ARCHIVE_ENABLED=false
ML_FEATURE_STORE_ENABLED=false
ML_NWP_EXTRA_FIELDS_ENABLED=false
ML_NWP_EXTRA_FIELDS_MAX_STEPS=24
ML_NWP_EXTRA_FIELDS_REQUEST_SLEEP_SEC=0.2
ML_NWP_VERTICAL_PROFILES_ENABLED=false
ML_NWP_VERTICAL_PROFILES_MAX_STEPS=5
ML_NWP_VERTICAL_PROFILES_PRESSURE_LEVELS_HPA=1000,925,850
ML_NWP_VERTICAL_PROFILES_REQUEST_SLEEP_SEC=0.2
ML_EUMETSAT_CLOUD_MASK_ENABLED=false
ML_EUMETSAT_CLOUD_MASK_POLL_INTERVAL_SEC=480
ML_EUMETSAT_CLOUD_MASK_WINDOW_MINUTES=120
ML_EUMETSAT_CLOUD_MASK_MAX_PRODUCTS=18
ML_EUMETSAT_THERMAL_PRODUCTS_ENABLED=false
ML_EUMETSAT_THERMAL_POLL_INTERVAL_SEC=900
ML_EUMETSAT_THERMAL_WINDOW_MINUTES=180
ML_EUMETSAT_THERMAL_MAX_PRODUCTS=12
EUMETSAT_CONSUMER_KEY=
EUMETSAT_CONSUMER_SECRET=

# Optional: expose the Wind2D web viewer on this host port.
WIND2D_WEB_PORT=8769

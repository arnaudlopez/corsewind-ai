METEOFRANCE_API_KEY=

# Optional: direct MeteoHub/CNR-ISAC MOLOCH GRIB/NetCDF bundle URL or local file.
# The builder also accepts a pre-normalized CorseWind JSON layer.
MOLOCH_SOURCE_URL=

# Optional: override the auto-discovered MeteoHub ICON-2I GRIB bundle URL/local file.
# Leave empty to let the ICON-2I builder select the latest public bundle.
ICON2I_SOURCE_URL=

# Optional: disable WindNinja case execution and WindNinja tile/data generation.
# Model layers still refresh. Re-enable later to compute the latest uncompleted
# AROME forcing run.
WINDNINJA_ENABLED=true

# Required when running docker-compose.forecast-engine.yml from a container.
# It must be the host path of this repository, because the engine launches
# WindNinja through the host Docker daemon.
# With Portainer Git stacks, set this to the host-side checkout directory used
# by Portainer for this repository, not to /app.
CORSEWIND_HOST_ROOT=/absolute/path/to/CorseWind.ai

# Optional: expose the Wind2D web viewer from docker-compose.forecast-engine.yml.
# Leave empty/undefined to run only the forecast engine.
# Set to wind2d-web to start the web service.
COMPOSE_PROFILES=
WIND2D_WEB_PORT=8769

FROM python:3.13-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /work

COPY requirements.txt requirements-ml-dataset.txt ./
RUN pip install --upgrade pip \
    && pip install -r requirements.txt -r requirements-ml-dataset.txt

CMD ["python", "--version"]
